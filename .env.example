# Z.AI GLM Coding Plan API key — https://z.ai/subscribe
GLM_API_KEY=your-z-ai-key

# Optional: OpenRouter API key. Picked up by Hermes' auxiliary "auto" chain
# (vision/web_extract/session_search side-tasks), so setting this stops the
# "marking openrouter unhealthy" warnings. Leave empty if you don't use it.
OPENROUTER_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Comma-separated numeric Telegram user IDs allowed to talk to the bot.
# Default-deny: if empty, Hermes refuses EVERYONE. Get your ID from @userinfobot.
TELEGRAM_ALLOWED_USERS=123456789

# Comma-separated Telegram group/supergroup chat IDs the bot is allowed to operate in.
# Supergroup IDs are negative (e.g. -1001234567890). Leave empty for DM-only.
TELEGRAM_GROUP_ALLOWED_CHATS=

# --- Akave persistent storage (rclone crypt) -------------------------------
# Used by the rclone sidecars (compose-akav.yaml / compose-openrouter.yaml) and
# by `just test-akave`. The connection test needs all six below.
#
# Create a bucket + access key pair at https://console.akave.com/ — the console
# shows a per-credential endpoint URL (copy it into AKAVE_ENDPOINT).
AKAVE_ENDPOINT=
AKAVE_ACCESS_KEY=
AKAVE_SECRET_KEY=
AKAVE_BUCKET=

# Client-side encryption for the bucket. BOTH values must be obscured first:
#   just obscure "$(openssl rand -base64 48)"   # -> RCLONE_CRYPT_PASSWORD
#   just obscure "$(openssl rand -base64 32)"   # -> RCLONE_CRYPT_SALT
# Save the ORIGINAL (un-obscured) values in a password manager: losing both the
# passphrase and the salt makes every file in the bucket unrecoverable.
RCLONE_CRYPT_PASSWORD=
RCLONE_CRYPT_SALT=

# Optional: seconds between sync cycles (sidecars only, default 300).
# SYNC_INTERVAL=300

# ───────────────────────── GATEWAY ─────────────────────────

# Comma-separated allowlist of Ethereum addresses (case-insensitive).
WALLET_WHITELIST=0xYourAddress1,0xYourAddress2

# Session-signing key. SECRET. MUST be stable and >= 32 chars. Generate with:
#   openssl rand -hex 32
WALLET_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Public host the dashboard is served from (no scheme). 
# On ROFL set this to the proxy host (oasis rofl machine show).
WALLET_DOMAIN=localhost:8080

