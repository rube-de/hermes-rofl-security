# Z.AI GLM Coding Plan API key — https://z.ai/subscribe
GLM_API_KEY=your-z-ai-key

# Optional: OpenRouter API key. Picked up by Hermes' auxiliary "auto" chain
# (vision/web_extract/session_search side-tasks), so setting this stops the
# "marking openrouter unhealthy" warnings. Leave empty if you don't use it.
OPENROUTER_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Comma-separated numeric Telegram user IDs allowed to talk to the bot.
# Default-deny: if empty, Hermes refuses EVERYONE. Get your ID from @userinfobot.
TELEGRAM_ALLOWED_USERS=123456789

# Comma-separated Telegram group/supergroup chat IDs the bot is allowed to operate in.
# Supergroup IDs are negative (e.g. -1001234567890). Leave empty for DM-only.
TELEGRAM_GROUP_ALLOWED_CHATS=
